# Copy to .env.staging and fill in your STAGING values.
# DO NOT commit .env.staging — it should be gitignored already.

# Staging Supabase project
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<staging service role key — bypasses RLS>
SUPABASE_ANON_KEY=<staging anon/publishable key>

# Axon API base for HTTP measurements
AXON_API_BASE_URL=https://<your-staging-domain>
AXON_AUTH_TOKEN=<a professor JWT for the institution that owns the test summary>

# OpenAI for parity check (script 02)
OPENAI_API_KEY=sk-...

# Filled by 00-find-test-summary.ts output
TEST_SUMMARY_ID=
TEST_INSTITUTION_ID=

# Filled by 01-baseline-publish.ts output (used by 04-post-change-validation)
BASELINE_P50_MS=
